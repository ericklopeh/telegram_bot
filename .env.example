# 1) Copia a .env:  cp .env.example .env   (o manual en Windows)
# 2) POSTGRES_PASSWORD debe ser la misma contraseña que en DATABASE_URL (usuario bot_user).
# 3) Postgres en Docker se publica en el host como localhost:5433 (evita choque con PG nativo en :5432).
#    El servicio `bot` en compose sobrescribe DATABASE_URL a host `db` dentro de la red Docker.

TELEGRAM_BOT_TOKEN=8682526788:AAFbxYOJigYk-Xy5I1nF2QYzmzWgbCtgjE4
# Semana ISO automática según DISPLAY_TIMEZONE (recomendado). Poner false para fijar SEMANA_ACTIVA a mano.
SEMANA_ACTIVA_AUTO=true
# Solo si SEMANA_ACTIVA_AUTO=false (ej. SEM 17-2026)
#SEMANA_ACTIVA=SEM 17-2026

POSTGRES_DB=bot_gaman
POSTGRES_USER=bot_user
POSTGRES_PASSWORD=Bgaman_2026_Postgres_Seguro!
POSTGRES_HOST=db
POSTGRES_PORT=5433

# SQLAlchemy: desde Windows (Alembic, `python app/main.py`) usa localhost:5433 (mapeo en docker-compose).
# El servicio `bot` en compose fuerza internamente host `db:5432`.
DATABASE_URL=postgresql+psycopg://bot_user:Bgaman_2026_Postgres_Seguro!@localhost:5433/bot_gaman

BASE_STORAGE_PATH=/app/storage
PEDIDOS_PATH=/app/storage/pedidos
REVISIONES_PATH=/app/storage/revisiones
# Opcional (prioridad sobre PEDIDOS_PATH / REVISIONES_PATH):
# RUTA_BASE_PEDIDOS=C:/ruta/pedidos
# RUTA_BASE_REVISIONES=C:/ruta/revisiones

CHAT_ID_PEDIDOS=0
CHAT_ID_COMPULSAS=0
# Grupo/canal opcional para alertas operativas a administradores.
CHAT_ID_ADMIN_ALERTS=0
COMPULSA_REMINDER_MINUTES=60
# IDs de usuario Telegram separados por coma.
# SELLER_USER_IDS=123456789   # piloto: un solo vendedor
# ADMIN_USER_IDS=987654321    # revisor/admin
SELLER_USER_IDS=
ADMIN_USER_IDS=
DISPLAY_TIMEZONE=America/Mexico_City
BUSINESS_HOURS_ENABLED=false
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=18:30
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_SITE_HOSTNAME=mgaman.sharepoint.com
MS_SITE_PATH=/sites/miunidad
MS_DRIVE_NAME=01_MIGRACIONgdrive
MS_ROOT_FOLDER=Mi unidad/Lingry Nuevo Leon/PEDIDOS
SHAREPOINT_RETRY_INTERVAL_MINUTES=5
SHAREPOINT_RETRY_MAX_ATTEMPTS=8
SLA_ALERT_INTERVAL_MINUTES=120
SLA_REVISION_MINUTES=240
SLA_AUTORIZACION_MINUTES=240
SLA_COMPULSA_MINUTES=180
